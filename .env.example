# ── Required ──────────────────────────────────────────────
# Hugging Face API token (get one at https://huggingface.co/settings/tokens)
HF_API_KEY=

# ── LLM ───────────────────────────────────────────────────
# Model to use via Hugging Face Inference API
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
# LLM_TIMEOUT=60

# ── Retrieval ─────────────────────────────────────────────
# VECTOR_TOP_K=10
# BM25_TOP_K=10
# RERANK_TOP_K=5
# MAX_CONTEXT_CHARS=3000

# ── Storage ───────────────────────────────────────────────
# CHROMA_PATH=./chroma_db
# UPLOAD_DIR=./uploads
# Clear vector store on application restart (set to 0 in production)
# CLEAR_CHROMA_ON_START=0

# ── Security & Limits ─────────────────────────────────────
# MAX_FILE_SIZE_MB=20
# MAX_DOCUMENTS_PER_SESSION=5
# UPLOAD_RATE_LIMIT=5
# QUESTION_RATE_LIMIT=20
# ALLOWED_ORIGINS=http://localhost:8000
