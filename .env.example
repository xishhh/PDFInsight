# Required: Hugging Face API token (get one at https://huggingface.co/settings/tokens)
HF_API_KEY=

# LLM model to use via Hugging Face Inference API
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Optional overrides (sensible defaults below)
# CHROMA_PATH=./chroma_db
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE_MB=20
# VECTOR_TOP_K=10
# BM25_TOP_K=10
# RERANK_TOP_K=5
# ALLOWED_ORIGINS=http://localhost:8000
